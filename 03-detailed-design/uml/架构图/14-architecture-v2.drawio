        <!-- Layer arrow 3→4 -->
        <mxCell id="arrow3" value="MyBatis-Plus / JDBC" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=10;strokeWidth=2;strokeColor=#666666;" edge="1" parent="1" source="layer-service" target="layer-data">
          <mxGeometry relative="1" as="geometry" />
