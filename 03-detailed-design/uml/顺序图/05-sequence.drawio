        </mxCell>
        <mxCell id="m10" value="锁定10分钟有效期" style="text;html=1;strokeColor=none;fillColor=#fff9c4;align=center;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="600" y="400" width="120" height="20" as="geometry" />
        </mxCell>
        <mxCell id="m11" value="UPDATE inventory" style="endArrow=block;endFill=1;strokeColor=#388e3c;" edge="1" parent="1">
