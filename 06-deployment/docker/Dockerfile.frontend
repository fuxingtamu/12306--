# 前端 Vue 3 Dockerfile
# 多阶段构建：Node编译 → Nginx运行

# ===== 阶段1：编译 =====
FROM node:18-alpine AS builder
WORKDIR /build
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

# ===== 阶段2：运行 =====
FROM nginx:1.25-alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /build/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
