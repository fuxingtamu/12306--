        <!-- 1. Query tickets -->
        <mxCell id="m1" value="1. 选择车次、日期" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="150" width="120" height="20" as="geometry" />
        </mxCell>
        <mxCell id="m2" value="GET /trains/{id}/inventory" style="endArrow=block;endFill=1;strokeColor=#1976d2;dashed=1;" edge="1" parent="1">
