        <!-- 4. Create order -->
        <mxCell id="m13" value="4. 确认订单" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="490" width="120" height="20" as="geometry" />
        </mxCell>
