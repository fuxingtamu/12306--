<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="部署图">
    <mxGraphModel dx="1400" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="12306旅客管理系统 — 部署图" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=18;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="450" y="15" width="400" height="30" as="geometry" />
        </mxCell>

        <!-- Client -->
        <mxCell id="node-client" value="«device»&#xa;客户端浏览器" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="180" height="80" as="geometry" />
        </mxCell>

        <!-- Nginx -->
        <mxCell id="node-nginx" value="«web server»&#xa;Nginx" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="80" width="180" height="80" as="geometry" />
        </mxCell>

        <!-- Docker Container -->
        <mxCell id="node-docker" value="«container» Docker (开发环境)" style="swimlane;startSize=26;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;dashed=1;container=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="70" width="500" height="330" as="geometry" />
        </mxCell>

        <!-- Spring Boot -->
        <mxCell id="node-app" value="«application»&#xa;Spring Boot 3.2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;fontStyle=1;" vertex="1" parent="node-docker">
          <mxGeometry x="30" y="40" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="app-detail" value="port: 8080 | /api&#xa;JVM 17" style="text;html=1;strokeColor=none;fillColor=none;fontSize=10;align=left;" vertex="1" parent="node-docker">
          <mxGeometry x="40" y="75" width="160" height="30" as="geometry" />
        </mxCell>

        <!-- MySQL -->
        <mxCell id="node-mysql" value="«database»&#xa;MySQL 8.0" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontStyle=1;" vertex="1" parent="node-docker">
          <mxGeometry x="30" y="170" width="140" height="80" as="geometry" />
        </mxCell>
        <mxCell id="mysql-detail" value="port: 3306&#xa;railway_system" style="text;html=1;strokeColor=none;fillColor=none;fontSize=10;align=left;" vertex="1" parent="node-docker">
          <mxGeometry x="45" y="205" width="110" height="30" as="geometry" />
        </mxCell>

        <!-- Redis -->
        <mxCell id="node-redis" value="«cache»&#xa;Redis" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" vertex="1" parent="node-docker">
          <mxGeometry x="230" y="180" width="110" height="65" as="geometry" />
        </mxCell>

        <!-- Flyway -->
        <mxCell id="node-flyway" value="«migration»&#xa;Flyway" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="node-docker">
          <mxGeometry x="260" y="40" width="110" height="55" as="geometry" />
        </mxCell>

        <!-- Dev Tools Container -->
        <mxCell id="node-dev" value="«development tools»" style="swimlane;startSize=26;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=11;dashed=1;container=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="450" width="500" height="110" as="geometry" />
        </mxCell>
        <mxCell id="dev-vite" value="Vite Dev Server&#xa;(HMR :3000)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=10;" vertex="1" parent="node-dev">
          <mxGeometry x="30" y="40" width="110" height="50" as="geometry" />
        </mxCell>
        <mxCell id="dev-swagger" value="Knife4j&#xa;(API文档)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="node-dev">
          <mxGeometry x="180" y="40" width="100" height="50" as="geometry" />
        </mxCell>
        <mxCell id="dev-eslint" value="ESLint +&#xa;Prettier" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="node-dev">
          <mxGeometry x="320" y="40" width="100" height="50" as="geometry" />
        </mxCell>

        <!-- Connections -->
        <mxCell id="conn1" value="HTTPS :443" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=10;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="node-client" target="node-nginx">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="conn2" value="proxy_pass :8080" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=10;strokeWidth=2;strokeColor=#d79b00;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="node-nginx" target="node-app">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="conn3" value="JDBC :3306" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=10;strokeWidth=2;strokeColor=#82b366;" edge="1" parent="1" source="node-app" target="node-mysql">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="conn4" value="Lettuce :6379" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=10;strokeWidth=2;strokeColor=#b85450;" edge="1" parent="1" source="node-app" target="node-redis">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="conn5" value="migration" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;fontSize=10;dashed=1;strokeColor=#666666;" edge="1" parent="1" source="node-flyway" target="node-mysql">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Rationale -->
        <mxCell id="rationale" value="部署设计理由：&#xa;1. 开发环境：Vite Dev Server (HMR port 3000) 直接 proxy 到 Spring Boot，无需 Nginx&#xa;2. 生产环境：Nginx 作为反向代理+静态文件服务器，统一入口 :443&#xa;3. Spring Boot 内嵌 Tomcat，单体部署无需外部Servlet容器&#xa;4. MySQL+Redis 单实例（开发/测试级别），HikariCP连接池默认10&#xa;5. Flyway 在应用启动时自动执行迁移，无需手动介入&#xa;6. H2 内存数据库用于 test profile，无需外部MySQL依赖&#xa;7. 不部署公网（内网/本地使用），CORS 仅需Vite proxy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="620" width="1060" height="110" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
