        <mxCell id="layer-data" value="数据层 (Database + Cache + Migration)" style="swimlane;startSize=30;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=13;container=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="620" width="1380" height="160" as="geometry" />
        </mxCell>
        <mxCell id="db-mysql" value="MySQL 8.0&#xa;(railway_system)&#xa;&#xa;users | passengers&#xa;stations | trains&#xa;train_stops | seat_types" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;fontStyle=1;" vertex="1" parent="layer-data">
          <mxGeometry x="60" y="50" width="150" height="80" as="geometry" />
        </mxCell>
        <mxCell id="db-redis" value="Redis&#xa;(缓存 + JWT黑名单)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="layer-data">
          <mxGeometry x="270" y="60" width="110" height="60" as="geometry" />
        </mxCell>
        <mxCell id="db-flyway" value="Flyway (SQL版本管理)&#xa;V1__schema.sql&#xa;V2__stations.sql&#xa;V3__trains.sql" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="layer-data">
          <mxGeometry x="440" y="50" width="150" height="80" as="geometry" />
        </mxCell>
        <mxCell id="db-config" value="多环境配置&#xa;dev: MySQL&#xa;test: H2&#xa;prod: MySQL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="layer-data">
          <mxGeometry x="650" y="50" width="130" height="70" as="geometry" />
        </mxCell>

        <!-- ===== 设计理由 ===== -->
        <mxCell id="rationale" value="分层设计理由：&#xa;1. 四层架构（表示→API→业务→数据）实现关注点分离，每层独立可测试&#xa;2. API 层仅做参数校验+路由+统一响应，不含业务逻辑&#xa;3. 业务层独立可单元测试（MockMvc+H2），不依赖Web容器&#xa;4. JWT Filter 在API层拦截，Service层不感知认证细节&#xa;5. MyBatis-Plus LambdaQueryWrapper 实现类型安全动态SQL&#xa;6. Flyway确保数据库变更可追溯、可回滚、环境一致&#xa;7. Redis预留：JWT黑名单（登出）、热门车站缓存" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="820" width="1380" height="90" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
